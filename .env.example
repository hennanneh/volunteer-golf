# Server Configuration
PORT=3001

# Allowed origins for WebSocket connections (comma-separated)
# Defaults to https://colonialvolunteers.golf,http://localhost:3001
ALLOWED_ORIGINS=https://colonialvolunteers.golf,http://localhost:3001

# Resend Email API (get your key at https://resend.com)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Your App <noreply@yourdomain.com>
